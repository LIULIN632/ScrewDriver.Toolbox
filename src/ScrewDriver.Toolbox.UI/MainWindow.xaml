<Window x:Class="ScrewDriver.Toolbox.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScrewDriver Toolbox" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="24,24,0,20">
                    <TextBlock Text="ScrewDriver" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="可信工具箱" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Background="Transparent" BorderThickness="0">
                    <StackPanel x:Name="NavContainer">
                        <!-- 启动 -->
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="StartPage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="启动" FontSize="14" VerticalAlignment="Center"/>
                        </Border>

                        <!-- 工具仓库（可折叠） -->
                        <Grid Height="48" Cursor="Hand" Tag="ToolRepositoryPage"
                              MouseLeftButtonDown="ToggleCategoryExpand">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Padding="16,0" Background="Transparent"
                                    Style="{StaticResource NavItemHover}">
                                <TextBlock Text="工具仓库" FontSize="14" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Grid.Column="1" x:Name="ExpandIcon" Text="▶" FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                        </Grid>

                        <!-- 分类子项（初始隐藏） -->
                        <StackPanel x:Name="CategoryPanel" Visibility="Collapsed"
                                    Background="{DynamicResource NavBackgroundBrush}">
                        </StackPanel>

                        <!-- 其他导航项 -->
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="SystemOptimizerPage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="系统优化" FontSize="14" VerticalAlignment="Center"/>
                        </Border>
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="RepairCenterPage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="系统修复" FontSize="14" VerticalAlignment="Center"/>
                        </Border>
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="HardwarePage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="硬件信息" FontSize="14" VerticalAlignment="Center"/>
                        </Border>
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="ScenariosPage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="场景方案" FontSize="14" VerticalAlignment="Center"/>
                        </Border>
                        <Border Padding="16,0" Height="48" Cursor="Hand"
                                Background="Transparent" Tag="SettingsPage"
                                Style="{StaticResource NavItemHover}"
                                MouseLeftButtonDown="NavItem_Click">
                            <TextBlock Text="设置" FontSize="14" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- 底部占位 -->
                <Border Grid.Row="2" Height="8"/>
            </Grid>
        </Border>

        <!-- 右侧内容区 -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="24"/>
    </Grid>
</Window>
