<Window x:Class="ScrewDriver.Toolbox.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScrewDriver Toolbox" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航 -->
        <Border Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Margin="24,24,0,20">
                    <TextBlock Text="ScrewDriver" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}"/>
                    <TextBlock Text="可信工具箱" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>

                <ListBox x:Name="NavListBox" Grid.Row="1" Background="Transparent"
                         BorderThickness="0" ItemContainerStyle="{StaticResource NavItemStyle}"
                         SelectionChanged="NavListBox_SelectionChanged">
                    <ListBoxItem Tag="StartPage">启动</ListBoxItem>
                    <ListBoxItem Tag="ToolRepositoryPage">工具仓库</ListBoxItem>
                    <ListBoxItem Tag="SystemOptimizerPage">系统优化</ListBoxItem>
                    <ListBoxItem Tag="RepairCenterPage">系统修复</ListBoxItem>
                    <ListBoxItem Tag="HardwarePage">硬件信息</ListBoxItem>
                    <ListBoxItem Tag="ScenariosPage">场景方案</ListBoxItem>
                    <ListBoxItem Tag="SettingsPage">设置</ListBoxItem>
                </ListBox>

                <!-- 底部占位 -->
                <Border Grid.Row="2" Height="8"/>
            </Grid>
        </Border>

        <!-- 右侧内容区 -->
        <Frame x:Name="MainFrame" Grid.Column="1" NavigationUIVisibility="Hidden" Margin="24"/>
    </Grid>
</Window>
