<Window x:Class="ScrewDriver.Toolbox.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
        xmlns:models="clr-namespace:ScrewDriver.Toolbox.Core.Models;assembly=ScrewDriver.Toolbox.Core"
        xmlns:pages="clr-namespace:ScrewDriver.Toolbox.UI.Views.Pages"
        xmlns:conv="clr-namespace:ScrewDriver.Toolbox.UI.Converters"
        Title="ScrewDriver Toolbox" Height="700" Width="1100"
        MinHeight="600" MinWidth="900"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <conv:ExpandIconConverter x:Key="ExpandIconConv"/>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:NumToVisibilityConverter x:Key="NumToVis"/>

        <DataTemplate DataType="{x:Type vm:StartPageViewModel}"><pages:StartPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:ToolRepositoryViewModel}"><pages:ToolRepositoryPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SystemSettingsProViewModel}"><pages:SystemSettingsProPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SoftwareOptimizeViewModel}"><pages:SoftwareOptimizePage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:PresetsViewModel}"><pages:PresetsPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:RepairCenterViewModel}"><pages:RepairCenterPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:HardwareViewModel}"><pages:HardwarePage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:DataCenterViewModel}"><pages:DataCenterPage/></DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}"><pages:SettingsPage/></DataTemplate>

        <!-- Sidebar nav item template -->
        <DataTemplate DataType="{x:Type models:NavigationItem}">
            <StackPanel>
                <!-- Parent item -->
                <Border x:Name="NavBorder" Margin="4,3" Padding="14,10" CornerRadius="10"
                        Background="Transparent" Cursor="Hand"
                        MouseLeftButtonDown="NavItem_Click" Tag="{Binding Tag}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="{Binding IconCode}" FontSize="22"
                                       VerticalAlignment="Center" Margin="0,0,12,0"
                                       IsHitTestVisible="False"/>
                            <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Medium"
                                       VerticalAlignment="Center" IsHitTestVisible="False"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding IsExpanded, Converter={StaticResource ExpandIconConv}}"
                                   FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"
                                   IsHitTestVisible="False"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   Visibility="{Binding SubItems.Count, Converter={StaticResource NumToVis}}"/>
                    </Grid>
                </Border>

                <!-- Sub items -->
                <ItemsControl ItemsSource="{Binding SubItems}" Margin="36,0,0,0"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="SubBorder" Margin="4,2" Padding="14,8" CornerRadius="8"
                                    Background="Transparent" Cursor="Hand"
                                    MouseLeftButtonDown="NavItem_Click" Tag="{Binding Tag}">
                                <TextBlock Text="{Binding Title}" FontSize="14"
                                           VerticalAlignment="Center" IsHitTestVisible="False"
                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                    <Setter TargetName="SubBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                    <Setter TargetName="SubBorder" Property="TextBlock.Foreground"
                                            Value="{DynamicResource PrimaryBrush}"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter TargetName="NavBorder" Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Left sidebar -->
        <Border Background="{DynamicResource NavBackgroundBrush}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8,12">
                    <TextBlock Text="ScrewDriver" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="16,8,12,20"/>
                    <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,4,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Right content area -->
        <Border Grid.Column="1" Background="{DynamicResource BackgroundBrush}">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="24"/>
        </Border>
    </Grid>
</Window>
