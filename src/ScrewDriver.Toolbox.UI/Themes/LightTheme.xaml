<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Developer Tool Light Theme -->

    <!-- 品牌色 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#16A34A"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1D4ED8"/>

    <!-- 表面色 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#CBD5E1"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#94A3B8"/>

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#475569"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#94A3B8"/>

</ResourceDictionary>
