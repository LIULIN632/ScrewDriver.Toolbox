<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 品牌色 - Developer Tool 风格 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#2563EB"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#DBEAFE"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#22C55E"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#EF4444"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#1D4ED8"/>

    <!-- 表面色 - 柔和高对比 -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#F3F4F6"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="#FAFBFC"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#D1D5DB"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#C4C4C4"/>

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E1E1E"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#999999"/>
</ResourceDictionary>
