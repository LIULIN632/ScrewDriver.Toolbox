<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Developer Tool Dark Theme -->

    <!-- 品牌色 -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#60A5FA"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171"/>
    <SolidColorBrush x:Key="InfoBrush" Color="#93BBFC"/>

    <!-- 表面色 — Developer Tool / IDE palette -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="NavBackgroundBrush" Color="#0F172A"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#334155"/>
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="#475569"/>
    <SolidColorBrush x:Key="ScrollThumbBrush" Color="#475569"/>

    <!-- 文字色 -->
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#64748B"/>

    <!-- 扩展 -->
    <SolidColorBrush x:Key="WarningBackgroundBrush" Color="#422006"/>
    <SolidColorBrush x:Key="WarningBorderBrush" Color="#D97706"/>
    <SolidColorBrush x:Key="DangerBackgroundBrush" Color="#450A0A"/>

</ResourceDictionary>
