<Application x:Class="ScrewDriver.Toolbox.UI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScrewDriver.Toolbox.UI.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml"/>
                <ResourceDictionary Source="Themes/Styles.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
            <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
            <conv:RecommendationToVisibilityConverter x:Key="RecToVis"/>
            <conv:StringToVisibilityConverter x:Key="StrToVis"/>
            <conv:ExpandIconConverter x:Key="ExpandIconConv"/>
            <conv:NumToVisibilityConverter x:Key="NumToVis"/>
            <conv:IconPathConverter x:Key="IconPathConverter"/>
            <conv:StringToBrushConverter x:Key="StringToBrush"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
