<Page x:Class="ScrewDriver.Toolbox.UI.Views.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="硬件检测">
    <Page.DataContext>
        <vm:HardwareViewModel/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题行 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="硬件检测" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock VerticalAlignment="Bottom" Margin="16,0,0,2"
                       FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                <Run Text="更新时间："/>
                <Run Text="{Binding RefreshTime, Mode=OneWay}"/>
            </TextBlock>
            <Button Content="刷新" Style="{StaticResource SecondaryButtonStyle}"
                    Width="72" Height="28" FontSize="11" Padding="0"
                    Margin="16,0,0,0" VerticalAlignment="Center"
                    Command="{Binding RefreshCommand}"/>
        </StackPanel>

        <!-- 系统摘要 -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
            <TextBlock Text="{Binding SystemSummary, Mode=OneWay}" FontSize="13"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </Border>

        <TextBlock Grid.Row="2" Text="CPU / GPU / 内存 / 磁盘 / 电池 · WMI 实时读取"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,12"/>

        <!-- 硬件卡片网格 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Components}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="310" MinHeight="150" Style="{StaticResource CardStyle}" Margin="6">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 图标 -->
                                <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="10"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        VerticalAlignment="Top" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Icon}" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 名称 + 主信息 -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding PrimaryInfo}" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- 副信息 -->
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SecondaryInfo}"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>

                                <!-- 健康状态 -->
                                <Border Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Padding="8,3"
                                        HorizontalAlignment="Left" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="normal">
                                                    <Setter Property="Background" Value="#E6F4EA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="warning">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="danger">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding HealthStatus}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="normal">
                                                        <Setter Property="Foreground" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="warning">
                                                        <Setter Property="Foreground" Value="#B45309"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="danger">
                                                        <Setter Property="Foreground" Value="{DynamicResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- 健康提示 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding TipText}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"
                                           Visibility="{Binding TipText, Converter={StaticResource StrToVis}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
