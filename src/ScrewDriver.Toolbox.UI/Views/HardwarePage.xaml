<Page x:Class="ScrewDriver.Toolbox.UI.Views.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="硬件信息">
    <Page.DataContext>
        <vm:HardwareViewModel/>
    </Page.DataContext>
    <Grid Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 标题 + 功能按钮 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="硬件信息" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="汇总本机型号、系统和关键硬件参数" Margin="0,6,0,0" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="详细信息" Height="30" FontSize="12" Padding="14,0"
                        Margin="0,0,8,0"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding DetailCommand}"/>
                <Button Content="刷新" Height="30" FontSize="12" Padding="14,0"
                        Margin="0,0,8,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="截图" Height="30" FontSize="12" Padding="14,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ScreenshotCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 2. 顶部 3 个概览卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 型号信息 -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="💻" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="型号信息" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding SystemModel}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SystemModelDetail}" FontSize="12"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 系统信息 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="🪟" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="系统信息" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding OsVersion}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding OsVersionDetail}" FontSize="12"
                                   Foreground="{DynamicResource TextTertiaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 运行时间 -->
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="运行时间" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                        <TextBlock Text="{Binding Uptime}" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="上次启动后至今" FontSize="12"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 3. 详细硬件列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="20">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HardwareItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,2" Height="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Label}" FontSize="13"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Value}" FontSize="13"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           TextWrapping="Wrap" VerticalAlignment="Center"
                                           Cursor="Hand" ToolTip="点击复制"
                                           MouseLeftButtonDown="CopyToClipboard"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>
