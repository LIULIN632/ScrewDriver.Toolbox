<Page x:Class="ScrewDriver.Toolbox.UI.Views.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="硬件信息">
    <Page.DataContext>
        <vm:HardwareViewModel/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 + 功能按钮 -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="硬件信息" FontSize="24" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="汇总本机型号、系统和关键硬件参数" Margin="0,6,0,0" FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                <Button Content="详细信息" Height="30" FontSize="12" Padding="14,0"
                        Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding DetailCommand}"/>
                <Button Content="刷新" Height="30" FontSize="12" Padding="14,0"
                        Margin="0,0,8,0" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"/>
                <Button Content="截图" Height="30" FontSize="12" Padding="14,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding ScreenshotCommand}"/>
            </StackPanel>
        </Grid>

        <!-- 顶部 3 个概览卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="💻" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="型号信息" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding SystemModel}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding SystemModelDetail}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="4,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="🪟" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="系统版本" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding OsVersion}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding OsVersionDetail}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                <StackPanel Orientation="Horizontal">
                    <Border Width="44" Height="44" CornerRadius="10"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="运行时间" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Uptime}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,4,0,0"/>
                        <TextBlock Text="上次启动后至今" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 详细硬件列表 -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="0">
            <Grid>
            <!-- 加载中 -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                  Height="80" VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="200" Height="4" IsIndeterminate="True"
                                 Foreground="{DynamicResource PrimaryBrush}"
                                 Background="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="正在检测硬件信息..." FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                </StackPanel>
            </Grid>
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HardwareItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- 模块标题 -->
                                <Border Height="36" Background="{DynamicResource NavBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,0"
                                        Visibility="{Binding IsHeader, Converter={StaticResource BoolToVis}}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🔹" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Label}" FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </Grid>
                                </Border>
                                <!-- 数据行 -->
                                <Grid Height="30"
                                      Visibility="{Binding IsHeader, Converter={StaticResource InverseBoolToVis}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{DynamicResource BackgroundBrush}"
                                            Margin="0,0,0,1" Padding="16,0,0,0">
                                        <TextBlock Text="{Binding Label}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <Border Grid.Column="1" Margin="0,0,0,1" Padding="12,0,16,0"
                                            Background="Transparent">
                                        <TextBlock Text="{Binding Value}" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"
                                                   Cursor="Hand" ToolTip="点击复制"
                                                   MouseLeftButtonDown="CopyToClipboard"/>
                                    </Border>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Page>
