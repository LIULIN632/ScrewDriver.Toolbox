<Page x:Class="ScrewDriver.Toolbox.UI.Views.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="硬件信息">
    <Page.DataContext>
        <vm:HardwareViewModel/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 + 操作按钮 -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="硬件信息" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Bottom" Margin="12,0,0,2"
                       FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                <Run Text="更新时间："/>
                <Run Text="{Binding RefreshTime, Mode=OneWay}"/>
            </TextBlock>
            <Button Grid.Column="2" Content="详细信息" Height="30" FontSize="12"
                    Padding="14,0" Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding DetailCommand}"/>
            <Button Grid.Column="3" Content="截图" Height="30" FontSize="12"
                    Padding="14,0" Margin="0,0,8,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ScreenshotCommand}"/>
            <Button Grid.Column="4" Content="刷新" Height="30" FontSize="12"
                    Padding="14,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- 顶部 3 个摘要卡片 -->
        <WrapPanel Grid.Row="1" Margin="0,0,0,20">
            <!-- 机型 -->
            <Border Width="240" Height="80" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="💻" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="机型" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding SystemModel}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding SystemModelDetail}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 系统版本 -->
            <Border Width="240" Height="80" Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="🪟" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="系统版本" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding OsVersion}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding OsVersionDetail}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 运行时长 -->
            <Border Width="240" Height="80" Style="{StaticResource CardStyle}">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" CornerRadius="8"
                            Background="{DynamicResource PrimaryLightBrush}"
                            VerticalAlignment="Center">
                        <TextBlock Text="⏱" FontSize="20"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="运行时长" FontSize="11"
                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                        <TextBlock Text="{Binding Uptime}" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="{Binding UptimeDetail}" FontSize="11"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </WrapPanel>

        <!-- 硬件组件卡片 -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Components}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="310" MinHeight="140" Style="{StaticResource CardStyle}" Margin="6">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 图标 -->
                                <Border Grid.RowSpan="2" Width="48" Height="48" CornerRadius="10"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        VerticalAlignment="Top" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding Icon}" FontSize="22"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- 名称 + 主信息（点击复制） -->
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Name}" FontSize="13"
                                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding PrimaryInfo}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"
                                               Cursor="Hand" ToolTip="点击复制"
                                               MouseLeftButtonDown="CopyToClipboard"/>
                                </StackPanel>

                                <!-- 副信息（点击复制） -->
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SecondaryInfo}"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" Margin="0,4,0,0"
                                           Cursor="Hand" ToolTip="点击复制"
                                           MouseLeftButtonDown="CopyToClipboard"/>

                                <!-- 健康状态 -->
                                <Border Grid.Row="2" Grid.Column="1" Margin="0,8,0,0" Padding="8,3"
                                        HorizontalAlignment="Left" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="normal">
                                                    <Setter Property="Background" Value="#E6F4EA"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="warning">
                                                    <Setter Property="Background" Value="#FEF3C7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding HealthLevel}" Value="danger">
                                                    <Setter Property="Background" Value="#FEE2E2"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding HealthStatus}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="normal">
                                                        <Setter Property="Foreground" Value="#166534"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="warning">
                                                        <Setter Property="Foreground" Value="#92400E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding HealthLevel}" Value="danger">
                                                        <Setter Property="Foreground" Value="#991B1B"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>

                                <!-- 健康提示 -->
                                <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding TipText}" FontSize="11"
                                           Foreground="{DynamicResource TextTertiaryBrush}"
                                           TextWrapping="Wrap" Margin="0,6,0,0"
                                           Visibility="{Binding TipText, Converter={StaticResource StrToVis}}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
