<Window x:Class="ScrewDriver.Toolbox.UI.Views.Controls.PresetEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑预设方案" Width="860" Height="620"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Metadata -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="基本信息" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,10"/>
                    <TextBlock Text="名称" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtName" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="标签" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtTag" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="描述" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtDesc" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Height="60" TextWrapping="Wrap" AcceptsReturn="True"
                             Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="图标 (Emoji)" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtIcon" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="适用场景" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtScene" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                             Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="预计效果" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtEffect" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                             Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                    <TextBlock Text="注意事项" FontSize="12" Margin="0,0,0,2"/>
                    <TextBox x:Name="TxtNotice" FontSize="13" Margin="0,0,0,10"
                             Padding="6,4" Height="50" TextWrapping="Wrap" AcceptsReturn="True"
                             Background="{DynamicResource CardBackgroundBrush}"
                             BorderBrush="{DynamicResource BorderBrush}"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Settings checklist -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="SettingsList" Margin="16,0,0,0">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding CategoryName}" FontSize="13" FontWeight="SemiBold"
                                           Margin="0,10,0,4" Foreground="{DynamicResource PrimaryBrush}"/>
                                <ItemsControl ItemsSource="{Binding Items}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,4" Padding="8,6">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox IsChecked="{Binding IsIncluded}"
                                                              VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding Name}" FontSize="12"
                                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="10"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextTrimming="CharacterEllipsis" MaxWidth="300"/>
                                                    </StackPanel>
                                                    <CheckBox Grid.Column="2" VerticalAlignment="Center"
                                                              IsChecked="{Binding TargetEnabled}"
                                                              IsEnabled="{Binding IsIncluded}"
                                                              Style="{StaticResource ToggleSwitchStyle}"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Bottom bar -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="保存" Height="32" FontSize="12" Padding="20,0"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"
                    Click="BtnSave_Click"/>
            <Button Content="取消" Height="32" FontSize="12" Padding="20,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
