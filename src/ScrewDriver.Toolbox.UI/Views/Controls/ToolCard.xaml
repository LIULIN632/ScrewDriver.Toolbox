<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Controls.ToolCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:ScrewDriver.Toolbox.UI.Converters">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:IconPathConverter x:Key="IconPathConverter"/>
    </UserControl.Resources>
    <Border Width="320" MinHeight="140" Style="{StaticResource CardStyle}" Margin="6">
        <Grid Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 图标 + 名称 + 状态 -->
            <StackPanel Orientation="Horizontal">
                <Grid Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Image Source="{Binding IconPath, Converter={StaticResource IconPathConverter}}"
                           Width="28" Height="28"/>
                </Grid>
                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <!-- 更新标签 -->
                <Border Margin="6,0,0,0" Padding="5,2" CornerRadius="8"
                        Background="{DynamicResource WarningBrush}"
                        Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="更新" FontSize="9" Foreground="#1E1E1E" FontWeight="SemiBold"/>
                </Border>
                <!-- 已安装标签 -->
                <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4"
                        Background="{DynamicResource PrimaryLightBrush}"
                        Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                    <TextBlock Text="已安装" FontSize="10"
                               Foreground="{DynamicResource InfoBrush}"/>
                </Border>
                <!-- 未安装标签 -->
                <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4"
                        Background="{DynamicResource BorderBrush}"
                        Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVis}}">
                    <TextBlock Text="未安装" FontSize="10"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                </Border>
            </StackPanel>

            <!-- 分类 + 风险 -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                <TextBlock Text="{Binding Category}" FontSize="11"
                           Foreground="{DynamicResource InfoBrush}"
                           Background="{DynamicResource PrimaryLightBrush}"
                           Padding="6,2"/>
                <TextBlock FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextTertiaryBrush}">
                    <Run Text="{Binding RiskLevel, Mode=OneWay, StringFormat='风险: {0}'}"/>
                </TextBlock>
            </StackPanel>

            <!-- 描述 -->
            <TextBlock Grid.Row="2" Text="{Binding Description}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                       Margin="0,6,0,0"/>

            <!-- 操作按钮 -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                <!-- 已安装：启动按钮 -->
                <Button x:Name="BtnLaunch" Content="启动" Height="28" FontSize="12" Padding="12,0"
                        Margin="0,0,6,0"
                        Command="{Binding LaunchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                        <Condition Binding="{Binding LaunchPath}" Value=""/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </MultiDataTrigger>
                                <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 未安装：安装按钮 -->
                <Button x:Name="BtnInstall" Content="安装" Height="28" FontSize="12"
                        Padding="12,0" Margin="0,0,6,0"
                        Command="{Binding InstallCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 官网下载按钮 -->
                <Button Content="官网" Height="28" FontSize="12"
                        Padding="10,0" Margin="0,0,6,0"
                        Click="OpenUrl_Click"
                        ToolTip="打开官网下载页面">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding OfficialUrl}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding OfficialUrl}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 更新按钮 -->
                <Button x:Name="BtnUpgrade" Content="更新" Height="28" FontSize="12"
                        Padding="12,0" Margin="0,0,6,0"
                        Command="{Binding UpgradeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="Height" Value="28"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasUpdate}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- ⋯ 更多 按钮 -->
                <Button Content="⋯" Height="28" Width="36" FontSize="14"
                        Padding="0" Margin="0,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="MoreButton_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
