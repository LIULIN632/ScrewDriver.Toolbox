<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Pages.SystemSettingsProPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="系统设置 Pro" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="一站式管理 Windows 系统设置，按分类浏览或搜索调整"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10" Padding="8,4" Margin="0,12,0,0"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MaxWidth="360">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="4,0,8,0"
                               Foreground="{DynamicResource TextTertiaryBrush}"/>
                    <TextBox Grid.Column="1" Style="{StaticResource SearchBoxStyle}"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="13"/>
                </Grid>
            </Border>
            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         Foreground="{DynamicResource PrimaryBrush}"
                         Background="Transparent" Maximum="100"/>

            <!-- Explorer restart banner -->
            <Border Background="#FFF4CE" BorderBrush="#F58B00" BorderThickness="1"
                    CornerRadius="6" Padding="15,10" Margin="0,10,0,0"
                    Visibility="{Binding PendingExplorerRestartCount, Converter={StaticResource NumToVis}}">
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="立即重启资源管理器"
                            Style="{StaticResource PrimaryButtonStyle}" Padding="12,5" FontSize="12"
                            Command="{Binding RestartExplorerCommand}"/>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="⚠️ " FontSize="14"/>
                        <TextBlock Text="您修改了 " Foreground="#333333" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PendingExplorerRestartCount}" FontWeight="Bold"
                                   Foreground="#F58B00" VerticalAlignment="Center"/>
                        <TextBlock Text=" 项需要重启资源管理器的设置，请点击右侧按钮使其生效。" Foreground="#333333" VerticalAlignment="Center"/>
                    </StackPanel>
                </DockPanel>
            </Border>
        </StackPanel>

        <!-- Row 1: Category chips -->
        <ItemsControl x:Name="ChipTabs" Grid.Row="1" ItemsSource="{Binding Categories}" Margin="0,0,0,14">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ChipBorderStyle}"
                            MouseLeftButtonDown="Category_Click">
                        <TextBlock Text="{Binding}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Row 2: Settings list -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,8">
                            <TextBlock Text="{Binding CategoryName}" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,10"/>
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <!-- Icon -->
                                                <Border Width="36" Height="36" CornerRadius="8"
                                                        Background="{DynamicResource PrimaryLightBrush}"
                                                        VerticalAlignment="Center" Margin="0,0,12,0"
                                                        Grid.RowSpan="3">
                                                    <TextBlock Text="{Binding IconCode}" FontSize="16"
                                                               FontFamily="Segoe UI Emoji"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <!-- Row 0: Name + badges -->
                                                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                    <Border Padding="6,1" CornerRadius="4" VerticalAlignment="Center" Margin="6,0,0,0"
                                                            Background="{Binding RiskBadgeColor, Converter={StaticResource StringToBrush}}">
                                                        <TextBlock Text="{Binding RiskLabel}" FontSize="10" Foreground="White"/>
                                                    </Border>
                                                    <Border Padding="6,1" CornerRadius="4" VerticalAlignment="Center" Margin="6,0,0,0"
                                                            Visibility="{Binding Recommendation, Converter={StaticResource RecToVis}}"
                                                            Background="{Binding RecommendationBadgeColor, Converter={StaticResource StringToBrush}}">
                                                        <TextBlock Text="{Binding RecommendationText}" FontSize="10" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>

                                                <!-- Toggle -->
                                                <CheckBox Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
                                                          IsChecked="{Binding IsEnabled}"
                                                          Style="{StaticResource ToggleSwitchStyle}"
                                                          VerticalAlignment="Center" Margin="16,0,0,0"/>

                                                <!-- Row 1: Description -->
                                                <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Description}"
                                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                                           MaxHeight="32" Margin="0,4,0,0"/>

                                                <!-- Row 2: Status bar -->
                                                <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                                    <TextBlock Text="当前: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                               Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"/>
                                                    <TextBlock Text=" · 建议: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    <TextBlock Text="{Binding RecommendationText, FallbackValue=—}" FontSize="11"
                                                               Foreground="{Binding RecommendationBadgeColor, Converter={StaticResource StringToBrush}}"/>
                                                    <TextBlock Text=" · 方式: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                                    <TextBlock Text="{Binding OperationType}" FontSize="11" Foreground="#999999"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Row 3: Restore bar -->
        <Border Grid.Row="3" Margin="0,12,0,0" Padding="14,10"
                Background="{DynamicResource CardBackgroundBrush}"
                CornerRadius="10" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
            <WrapPanel HorizontalAlignment="Center">
                <TextBlock Text="恢复默认：" FontSize="12" VerticalAlignment="Center"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,10,0"/>
                <Button Content="资源管理器" Click="RestoreCategory_Click" Tag="资源管理器"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="个性化" Click="RestoreCategory_Click" Tag="个性化"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="桌面" Click="RestoreCategory_Click" Tag="桌面"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="任务栏" Click="RestoreCategory_Click" Tag="任务栏"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="开始菜单" Click="RestoreCategory_Click" Tag="开始菜单"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="系统界面" Click="RestoreCategory_Click" Tag="系统界面"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="隐私与搜索" Click="RestoreCategory_Click" Tag="隐私与搜索"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="性能与电源" Click="RestoreCategory_Click" Tag="性能与电源"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Button Content="安全与更新" Click="RestoreCategory_Click" Tag="安全与更新"
                        Style="{StaticResource OptCardStyle}"
                        Padding="10,5" FontSize="11" Margin="0,0,6,4"/>
                <Border Width="1" Background="{DynamicResource BorderBrush}" Margin="6,2"/>
                <Button Content="恢复全部" Click="RestoreAll_Click"
                        Background="#EF4444" Foreground="White"
                        BorderThickness="0" Padding="14,5" FontSize="11" FontWeight="SemiBold"
                        Cursor="Hand" Margin="6,0,0,4">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </WrapPanel>
        </Border>
    </Grid>
</UserControl>
