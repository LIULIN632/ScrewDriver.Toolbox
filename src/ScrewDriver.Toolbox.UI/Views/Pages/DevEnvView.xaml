<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Pages.DevEnvView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" Height="600" Width="800">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. 环境诊断 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="环境诊断" FontSize="20" FontWeight="Bold"/>
            <Button Content="刷新" Command="{Binding RefreshDiagnosticsCommand}" Margin="20,0,0,0" Padding="10,5"/>
        </StackPanel>

        <DataGrid Grid.Row="1" ItemsSource="{Binding Diagnostics}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="项目" Binding="{Binding Name}" Width="180"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="100"/>
                <DataGridTextColumn Header="详情" Binding="{Binding Message}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 2. 镜像源管理 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,20,0,10">
            <TextBlock Text="镜像源管理" FontSize="20" FontWeight="Bold"/>
            <Button Content="刷新" Command="{Binding RefreshDiagnosticsCommand}" Margin="20,0,0,0" Padding="10,5"/>
        </StackPanel>

        <DataGrid Grid.Row="3" ItemsSource="{Binding ActivePorts}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="本地端口" Binding="{Binding Port}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding State}" Width="120"/>
                <DataGridTextColumn Header="进程名" Binding="{Binding ProcessName}" Width="150"/>
                <DataGridTextColumn Header="PID" Binding="{Binding PID}" Width="100"/>
                <DataGridTemplateColumn Header="操作" Width="100">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="结束进程" Command="{Binding DataContext.KillProcessCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding PID}"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
