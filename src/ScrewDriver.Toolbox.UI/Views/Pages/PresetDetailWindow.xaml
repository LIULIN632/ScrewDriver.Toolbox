<Window x:Class="ScrewDriver.Toolbox.UI.Views.Pages.PresetDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="预设方案详情" Width="580" Height="520"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        ResizeMode="NoResize"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <Border Width="40" Height="40" CornerRadius="8"
                        Background="{DynamicResource PrimaryLightBrush}">
                    <TextBlock Text="{Binding IconCode}" FontSize="20"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel Margin="12,0,0,0">
                    <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Tag}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource CardStyle}" Padding="14">
                    <StackPanel>
                        <TextBlock Text="适用场景" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Scene}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                        <TextBlock Text="预计效果" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Effect}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                        <TextBlock Text="注意事项" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource WarningBrush}"/>
                        <TextBlock Text="{Binding Notice}" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭" Height="32" FontSize="12" Padding="20,0"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,8,0"
                    Click="BtnClose_Click"/>
            <Button Content="一键应用" Height="32" FontSize="12" Padding="20,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnApply_Click"/>
        </StackPanel>
    </Grid>
</Window>
