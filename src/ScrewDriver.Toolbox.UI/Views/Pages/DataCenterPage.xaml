<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Pages.DataCenterPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="clr-namespace:ScrewDriver.Toolbox.UI.Converters"
      Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>
    <Grid Margin="4,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="数据中心" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="配置备份 · 系统报告 · 操作日志"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 快捷操作卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="📦" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock Text="配置备份" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="备份/恢复系统设置快照" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <Button Content="创建备份" Style="{StaticResource PrimaryButtonStyle}" Height="30" FontSize="12"
                            Command="{Binding CreateBackupCommand}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="4,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="📊" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock Text="系统报告" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="生成系统检测/验机报告" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="TXT" Height="30" FontSize="12" Margin="0,0,6,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding GenerateTextReportCommand}"/>
                        <Button Content="HTML" Height="30" FontSize="12"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding GenerateHtmlReportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="📋" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock Text="操作日志" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="查看系统操作历史记录" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <Button Content="刷新日志" Height="30" FontSize="12"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding RefreshLogsCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 第二行：配置管理 -->
        <Grid Grid.Row="2" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,8,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="💾" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock Text="配置导入/导出" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="保存/恢复系统优化配置" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="导出配置" Height="30" FontSize="12" Margin="0,0,6,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding ExportConfigCommand}"/>
                        <Button Content="导入配置" Height="30" FontSize="12"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ImportConfigCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="8,0,0,0" Padding="16,14">
                <StackPanel>
                    <TextBlock Text="💿" FontSize="24" Margin="0,0,0,8"/>
                    <TextBlock Text="Autounattend.xml" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="自动化装机配置文件生成" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,12"/>
                    <Button Content="生成 XML" Height="30" FontSize="12"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding GenerateAutounattendCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 下方双栏：备份列表 + 日志/报告 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：备份列表 + 日志列表 -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- 备份列表 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="备份列表" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <TextBox Text="{Binding BackupRemark, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource SearchBoxStyle}" Margin="0,0,0,6"/>
                            <ListBox ItemsSource="{Binding BackupList}" SelectedItem="{Binding SelectedBackup}"
                                     BorderThickness="0" Background="Transparent" MaxHeight="280"
                                     SelectionChanged="BackupList_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,8">
                                            <TextBlock FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                                <Run Text="{Binding CreateTime, StringFormat='{}{0:yyyy-MM-dd HH:mm}'}"/>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Remark}" FontSize="12"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}">
                                                <Run Text="{Binding ItemCount, StringFormat='包含 {0} 项设置'}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="恢复" Height="26" FontSize="11" Padding="10,0" Margin="0,0,4,0"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding RestoreBackupCommand}"/>
                                <Button Content="导出" Height="26" FontSize="11" Padding="10,0" Margin="0,0,4,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding ExportBackupCommand}"/>
                                <Button Content="删除" Height="26" FontSize="11" Padding="10,0"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Command="{Binding DeleteBackupCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 日志文件列表 -->
                    <Border Style="{StaticResource CardStyle}" Padding="12">
                        <StackPanel>
                            <TextBlock Text="日志文件" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                            <ListBox ItemsSource="{Binding LogFiles}" SelectedItem="{Binding SelectedLogFile}"
                                     BorderThickness="0" Background="Transparent" MaxHeight="200">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   Text="{Binding}"/>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- 右侧：日志内容 / 报告预览 -->
            <Grid Grid.Column="1" Margin="12,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox Text="{Binding LogFilter, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" Style="{StaticResource SearchBoxStyle}" Margin="0,0,8,0"/>
                    <Button Content="复制报告" Height="26" FontSize="11" Padding="10,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding CopyReportCommand}"/>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Padding="12">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBlock Text="{Binding LogContent}" FontFamily="Consolas" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="NoWrap"/>
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
