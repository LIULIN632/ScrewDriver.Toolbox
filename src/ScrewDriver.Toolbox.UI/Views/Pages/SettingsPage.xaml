<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Loaded="Page_Loaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- ========== 外观 ========== -->
            <TextBlock Text="外观" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <StackPanel>
                    <TextBlock Text="主题" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button x:Name="LightThemeBtn" Content="浅色" Width="100" Height="36" FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="LightTheme_Click"/>
                        <Button x:Name="DarkThemeBtn" Content="深色" Width="100" Height="36" FontSize="13"
                                Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                Click="DarkTheme_Click"/>
                        <Button x:Name="SystemThemeBtn" Content="跟随系统" Width="100" Height="36" FontSize="13"
                                Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                Click="SystemTheme_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== 通用 ========== -->
            <TextBlock Text="通用" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <StackPanel>
                    <!-- 托盘模式 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="关闭到托盘" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="关闭窗口时最小化到系统托盘，而不是退出程序"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="MinimizeToTrayCheck"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center" Checked="MinimizeToTray_Changed" Unchecked="MinimizeToTray_Changed"/>
                    </Grid>

                    <!-- 开机自启 -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="开机自启" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                            </StackPanel>
                            <TextBlock Text="系统启动时自动运行 ScrewDriver Toolbox"
                                       FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox Grid.Column="1" x:Name="AutoStartCheck"
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  VerticalAlignment="Center" Checked="AutoStart_Changed" Unchecked="AutoStart_Changed"/>
                    </Grid>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="重新扫描工具图标" Height="32" FontSize="12" Padding="14,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="RescanIcons_Click"/>
                        <Button Content="恢复默认设置" Height="32" FontSize="12" Padding="14,0"
                                Style="{StaticResource DangerButtonStyle}" Margin="12,0,0,0"
                                Click="RestoreDefaults_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== 更新 ========== -->
            <TextBlock Text="更新" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}">
                                <Run Text="当前版本 v"/>
                                <Run Text="{Binding Version, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock x:Name="TxtUpdateStatus" Text="点击检查更新" FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" x:Name="BtnCheckUpdate" Content="检查更新"
                                Height="32" FontSize="12" Padding="14,0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Click="CheckUpdate_Click" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ========== 关于 ========== -->
            <TextBlock Text="关于" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="ScrewDriver Toolbox" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Runtime, Mode=OneWay}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding ToolCount, Mode=OneWay}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="参考 DevToys + PowerToys + Windows 11 设计，打造 Windows 用户可信赖的系统工具箱"
                               FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,8,0,0" FontSize="13">
                        <Hyperlink NavigateUri="https://github.com/LIULIN632/ScrewDriver.Toolbox" Click="GitHubLink_Click"
                                   Foreground="{DynamicResource PrimaryBrush}">
                            GitHub →
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
