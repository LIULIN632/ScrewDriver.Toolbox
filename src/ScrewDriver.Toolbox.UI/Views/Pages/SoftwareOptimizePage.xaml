<UserControl x:Class="ScrewDriver.Toolbox.UI.Views.Pages.SoftwareOptimizePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{DynamicResource BackgroundBrush}">
    <UserControl.Resources>
        <Style x:Key="ChipBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="软件优化" FontSize="26" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="优化 Edge、Office、WPS 等软件设置，关闭广告推送和后台占用"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
            <ProgressBar IsIndeterminate="True" Height="3" Margin="0,10,0,0"
                         Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}"
                         Foreground="{DynamicResource PrimaryBrush}"
                         Background="Transparent" Maximum="100"/>
        </StackPanel>

        <!-- Row 1: Software chips -->
        <ItemsControl x:Name="ChipTabs" Grid.Row="1" ItemsSource="{Binding SoftwareList}" Margin="0,0,0,14">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource ChipBorderStyle}"
                            MouseLeftButtonDown="Chip_Click">
                        <TextBlock Text="{Binding}" FontSize="13"
                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Row 2: Toggle cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Items}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Icon -->
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0"
                                        Grid.RowSpan="3">
                                    <TextBlock Text="🔧" FontSize="16"
                                               FontFamily="Segoe UI Emoji"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <!-- Row 0: Name -->
                                <TextBlock Grid.Column="1" Grid.Row="0"
                                           Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           VerticalAlignment="Center"/>

                                <!-- Toggle (for Toggle items) -->
                                <CheckBox Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
                                          IsChecked="{Binding IsEnabled}"
                                          Visibility="{Binding IsToggle, Converter={StaticResource BoolToVis}}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center" Margin="16,0,0,0"/>

                                <!-- Action button (for ActionButton items) -->
                                <Button Grid.Column="2" Grid.Row="0" Grid.RowSpan="3"
                                        Content="{Binding ActionButtonText}"
                                        Visibility="{Binding IsAction, Converter={StaticResource BoolToVis}}"
                                        Command="{Binding DataContext.ApplyActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center" Margin="16,0,0,0"
                                        FontSize="12" Padding="10,6" Cursor="Hand"
                                        Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                        BorderThickness="0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>

                                <!-- Row 1: Description -->
                                <TextBlock Grid.Column="1" Grid.Row="1"
                                           Text="{Binding Description}"
                                           FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                           MaxHeight="32" Margin="0,4,0,0"/>

                                <!-- Row 2: Status bar -->
                                <StackPanel Grid.Column="1" Grid.Row="2" Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="状态: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{Binding StatusColor, Converter={StaticResource StringToBrush}}"/>
                                    <TextBlock Text=" · 方式: " FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    <TextBlock Text="{Binding OperationType}" FontSize="11" Foreground="#999999"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>
