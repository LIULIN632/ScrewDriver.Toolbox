<Page x:Class="ScrewDriver.Toolbox.UI.Views.ScenariosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="内置工具"
      Background="{DynamicResource BackgroundBrush}">
    <Page.DataContext>
        <vm:ScenarioViewModel/>
    </Page.DataContext>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 主区域：居中标题 -->
        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="内置工具" FontSize="28" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
            <TextBlock Text="常用系统快捷工具" FontSize="14"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 底部固定快捷栏：4项工具 -->
        <Border Grid.Row="1">
            <StackPanel>
                <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="0,0,0,16"/>
                <UniformGrid Columns="4">
                    <!-- Hosts 编辑 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="📝" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Hosts 编辑" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="可视化编辑系统Hosts文件" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="运行" Height="28" FontSize="11" Padding="10,0"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding HostsCommand}"/>
                        </Grid>
                    </Border>

                    <!-- KMS 激活 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="🔑" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="KMS 激活" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="查看系统激活状态" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="运行" Height="28" FontSize="11" Padding="10,0"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding KmsCommand}"/>
                        </Grid>
                    </Border>

                    <!-- WiFi 密码 -->
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,16,0" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="📶" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="WiFi 密码" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="查看已连接WiFi的密码" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="运行" Height="28" FontSize="11" Padding="10,0"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding WifiCommand}"/>
                        </Grid>
                    </Border>

                    <!-- 证书拦截 -->
                    <Border Style="{StaticResource CardStyle}" Padding="14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" CornerRadius="8"
                                    Background="{DynamicResource PrimaryLightBrush}"
                                    VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="🛡️" FontSize="16"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="证书拦截" FontSize="13" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="管理受信任的根证书" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="2" Content="运行" Height="28" FontSize="11" Padding="10,0"
                                    Style="{StaticResource PrimaryButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding CertCommand}"/>
                        </Grid>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Border>
    </Grid>
</Page>
