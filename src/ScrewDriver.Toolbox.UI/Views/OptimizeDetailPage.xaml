<Page x:Class="ScrewDriver.Toolbox.UI.Views.OptimizeDetailPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="优化详情"
      Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="28,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="← 返回" Height="32" FontSize="12" Padding="14,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="BtnBack_Click" Margin="0,0,16,0"/>
                <TextBlock x:Name="TxtTitle" FontSize="26" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <ItemsControl x:Name="SettingList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding IconCode}" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <Border Padding="5,1" CornerRadius="4" Margin="8,0,0,0"
                                                Background="#FEE2E2" VerticalAlignment="Center"
                                                Visibility="{Binding IsDangerous, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="高风险" FontSize="10" Foreground="#991B1B"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                               Foreground="{Binding StatusColor}" Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="2" IsChecked="{Binding IsEnabled}"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center" Margin="16,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 多选下拉设置 -->
            <ItemsControl ItemsSource="{Binding ComboItems}" Margin="0,8,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="{Binding IconCode}" FontSize="16"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="0,4,0,0"/>
                                    <ComboBox ItemsSource="{Binding Options}"
                                              SelectedValue="{Binding SelectedValue}"
                                              SelectedValuePath="Value"
                                              DisplayMemberPath="DisplayName"
                                              Height="28" FontSize="12" Margin="0,6,0,0"
                                              Background="{DynamicResource CardBackgroundBrush}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
