<Page x:Class="ScrewDriver.Toolbox.UI.Views.SystemOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      xmlns:models="clr-namespace:ScrewDriver.Toolbox.Core.Models"
      Title="系统优化">
    <Page.DataContext>
        <vm:SystemOptimizerViewModel/>
    </Page.DataContext>
    <Page.Resources>
        <Style x:Key="RiskBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="5,1"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="系统优化" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" Text="调节 Windows 隐藏设置，提升性能与隐私保护"
                   FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding GroupedSettings}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Expander Margin="0,0,0,6" IsExpanded="True"
                                      Background="{DynamicResource CardBackgroundBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      BorderThickness="1">
                                <Expander.Header>
                                    <Border Padding="14,10" Background="{DynamicResource NavBackgroundBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding CategoryName}" FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center" Margin="8,0,0,0">
                                                    <Run Text="{Binding Items.Count, Mode=OneWay, StringFormat='{}（{0} 项）'}"/>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="2" Content="恢复本组默认"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Height="28" FontSize="11" Padding="10,0"
                                                    Command="{Binding DataContext.RevertGroupCommand, RelativeSource={RelativeSource AncestorType=Page}}"
                                                    CommandParameter="{Binding CategoryName}"/>
                                        </Grid>
                                    </Border>
                                </Expander.Header>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="4">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBackgroundBrush}"
                                                    CornerRadius="8" Margin="4" Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <!-- 左侧：文字 + 风险标签 -->
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Name}" FontSize="14"
                                                                       FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                            <!-- 推荐标签 -->
                                                            <Border CornerRadius="4" Padding="5,1" Margin="8,0,0,0"
                                                                    VerticalAlignment="Center"
                                                                    Background="{DynamicResource PrimaryLightBrush}"
                                                                    Visibility="{Binding Recommendation, Converter={StaticResource RecToVis}}">
                                                                <TextBlock Text="{Binding RecommendationText}" FontSize="10"
                                                                           Foreground="{DynamicResource PrimaryBrush}"/>
                                                            </Border>
                                                            <!-- 安全 -->
                                                            <Border>
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource RiskBadgeStyle}">
                                                                        <Setter Property="Background" Value="#DCFCE7"/>
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Recommended">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="安全" FontSize="10" Foreground="{DynamicResource SuccessBrush}"/>
                                                            </Border>
                                                            <!-- 可选 -->
                                                            <Border>
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource RiskBadgeStyle}">
                                                                        <Setter Property="Background" Value="#FEF3C7"/>
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Optional">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="注意" FontSize="10" Foreground="{DynamicResource WarningBrush}"/>
                                                            </Border>
                                                            <!-- 高风险 -->
                                                            <Border>
                                                                <Border.Style>
                                                                    <Style TargetType="Border" BasedOn="{StaticResource RiskBadgeStyle}">
                                                                        <Setter Property="Background" Value="#FEE2E2"/>
                                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding RiskLevel}" Value="Dangerous">
                                                                                <Setter Property="Visibility" Value="Visible"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Border.Style>
                                                                <TextBlock Text="高风险" FontSize="10" Foreground="{DynamicResource ErrorBrush}"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                    </StackPanel>
                                                    <!-- 右侧：ToggleSwitch -->
                                                    <CheckBox Grid.Column="1"
                                                              IsChecked="{Binding IsEnabled}"
                                                              Style="{StaticResource ToggleSwitchStyle}"
                                                              VerticalAlignment="Center"
                                                              Margin="16,0,0,0"
                                                              Click="SettingCheckBox_Click"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Bloatware batch uninstall -->
                <Border Style="{StaticResource CardStyle}" Margin="0,8,0,8" Padding="16">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="预装应用卸载" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Background="#FEE2E2" CornerRadius="4"
                                    Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="不可恢复" FontSize="10"
                                           Foreground="{DynamicResource ErrorBrush}"/>
                            </Border>
                        </StackPanel>

                        <TextBlock Text="勾选要卸载的 Windows 预装应用，然后点击「卸载所选」批量移除"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" Margin="0,0,0,10"/>

                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="全选" Width="56" Height="26" FontSize="11"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding SelectAllBloatwareCommand}"/>
                            <Button Content="取消全选" Width="68" Height="26" FontSize="11"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="8,0,0,0"
                                    Command="{Binding DeselectAllBloatwareCommand}"/>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextTertiaryBrush}"
                                       VerticalAlignment="Center" Margin="12,0,0,0">
                                <Run Text="{Binding BloatwareList.Count, Mode=OneWay, StringFormat='{}共 {0} 项'}"/>
                            </TextBlock>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding BloatwareList}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox Content="{Binding DisplayName}"
                                              IsChecked="{Binding IsSelected}"
                                              FontSize="12" Margin="0,3"
                                              Foreground="{DynamicResource TextPrimaryBrush}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Grid Margin="0,12,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button Content="卸载所选"
                                    Width="120" Height="36" FontSize="13"
                                    Command="{Binding UninstallSelectedBloatwareCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsUninstalling}" Value="True">
                                                <Setter Property="IsEnabled" Value="False"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>

                            <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center"
                                        Visibility="{Binding IsUninstalling, Converter={StaticResource BoolToVis}}">
                                <ProgressBar Height="6" IsIndeterminate="True" Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding UninstallStatus}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Button Grid.Row="3" Content="全部恢复默认" Style="{StaticResource DangerButtonStyle}"
                Width="160" HorizontalAlignment="Right" Margin="0,16,0,0"
                Click="RevertAll_Click"/>
    </Grid>
</Page>
