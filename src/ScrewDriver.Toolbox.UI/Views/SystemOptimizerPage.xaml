<Page x:Class="ScrewDriver.Toolbox.UI.Views.SystemOptimizerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="系统优化"
      Background="{DynamicResource BackgroundBrush}">
    <Page.DataContext>
        <vm:SystemOptimizerViewModel/>
    </Page.DataContext>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0" Background="{DynamicResource NavBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                Padding="12,24">
            <StackPanel>
                <RadioButton GroupName="OptNav" IsChecked="True"
                             Command="{Binding SwitchNavCommand}" CommandParameter="Optimize"
                             Margin="0,0,0,4">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <Border CornerRadius="8" Padding="10,12"
                                    Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⚡" FontSize="16" VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryBrush}"/>
                                    <TextBlock Text="优化" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>

                <RadioButton GroupName="OptNav" Margin="0,0,0,4"
                             Command="{Binding SwitchNavCommand}" CommandParameter="Custom">
                    <RadioButton.Template>
                        <ControlTemplate TargetType="RadioButton">
                            <Border CornerRadius="8" Padding="10,12"
                                    Background="{TemplateBinding Background}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🔧" FontSize="16" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                                    <TextBlock Text="自定义" FontSize="14"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               Margin="10,0,0,0" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryLightBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </RadioButton.Template>
                </RadioButton>
            </StackPanel>
        </Border>

            <!-- 右侧主内容区 -->
        <Grid Grid.Column="1" Margin="28,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 顶部标题 -->
            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                <TextBlock Text="{Binding PageTitle}" FontSize="32" FontWeight="Bold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding PageSubtitle}" FontSize="14"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- 分类卡片列表 -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource OptCardStyle}" Margin="0,0,0,12"
                                    Command="{Binding NavigateCommand}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- 彩色图标 -->
                                    <Border Width="44" Height="44" CornerRadius="10"
                                            Background="{DynamicResource PrimaryLightBrush}"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding IconCode}" FontSize="22"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>

                                    <!-- 标题+描述 -->
                                    <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Title}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                                            <!-- 新功能角标 -->
                                            <Border Background="#DC2626" CornerRadius="4" Padding="5,1"
                                                    Margin="8,0,0,0" VerticalAlignment="Center"
                                                    Visibility="{Binding HasNewBadge, Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="{Binding NewBadgeText}" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Description}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- 右箭头 -->
                                    <TextBlock Grid.Column="2" Text="→" FontSize="18"
                                               Foreground="{DynamicResource TextTertiaryBrush}"
                                               VerticalAlignment="Center" Margin="12,0,0,0"/>
                                </Grid>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
