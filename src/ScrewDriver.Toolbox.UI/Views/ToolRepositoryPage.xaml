<Page x:Class="ScrewDriver.Toolbox.UI.Views.ToolRepositoryPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      xmlns:conv="clr-namespace:ScrewDriver.Toolbox.UI.Converters"
      Title="工具仓库"
      AllowDrop="True"
      DragEnter="Page_DragEnter"
      Drop="Page_Drop">
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis"/>
        <conv:IconPathConverter x:Key="IconPathConverter"/>
    </Page.Resources>
    <Page.DataContext>
        <vm:ToolRepositoryViewModel/>
    </Page.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="工具仓库" FontSize="24" FontWeight="Bold"
                   Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>

        <!-- 扫描进度 -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}" Margin="0,0,0,10"
                Padding="10,6" Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar Width="16" Height="16" IsIndeterminate="True" Margin="0,0,8,0"/>
                <TextBlock Text="正在检测已安装工具..." FontSize="13"
                           Foreground="{DynamicResource TextSecondaryBrush}" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 推荐工具 Banner -->
        <StackPanel Grid.Row="1" Margin="0,0,0,16"
                    Visibility="{Binding RecommendedTools.Count, Converter={StaticResource BoolToVis}}">
            <TextBlock Text="推荐工具" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,10"/>
            <ItemsControl ItemsSource="{Binding RecommendedTools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="200" Style="{StaticResource CardStyle}"
                                Margin="0,0,12,0" Padding="14" Cursor="Hand"
                                MouseLeftButtonDown="RecommendedTool_Click">
                            <StackPanel>
                                <Grid Width="32" Height="32" Margin="0,0,0,8">
                                    <Image Source="{Binding IconPath, Converter={StaticResource IconPathConverter}}"
                                           Width="32" Height="32"/>
                                </Grid>
                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="{Binding Description}" FontSize="11"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                <TextBlock Text="{Binding Category}" FontSize="10"
                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- 搜索栏 + 操作按钮 -->
        <Grid Grid.Row="2" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    CornerRadius="10" Padding="6,2"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                <TextBox Style="{StaticResource SearchBoxStyle}"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
            </Border>
            <Button Grid.Column="1" Content="扫描本地" Height="32" FontSize="12"
                    Margin="12,0,0,0" Padding="12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ScanLocalFolderCommand}"/>
            <Button Grid.Column="2" Content="清除" Height="32" FontSize="12"
                    Margin="8,0,0,0" Padding="12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding ClearLocalScanCommand}"/>
            <Button Grid.Column="3" Content="检查更新" Height="32" FontSize="12"
                    Margin="8,0,0,0" Padding="12,0"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Command="{Binding CheckForUpdatesCommand}"/>
            <TextBlock Grid.Column="4" Text="正在检查更新..." FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="8,0,0,0" VerticalAlignment="Center"
                       Visibility="{Binding IsCheckingForUpdates, Converter={StaticResource BoolToVis}}"/>
        </Grid>


        <!-- 工具卡片列表 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FilteredTools}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="320" MinHeight="140" Style="{StaticResource CardStyle}" Margin="6">
                            <Grid Margin="4">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- 图标 + 名称 + 状态 -->
                                <StackPanel Orientation="Horizontal">
                                    <Grid Width="28" Height="28" Margin="0,0,8,0" VerticalAlignment="Center">
                                        <Image Source="{Binding IconPath, Converter={StaticResource IconPathConverter}}"
                                               Width="28" Height="28"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <!-- 更新标签 -->
                                    <Border Margin="6,0,0,0" Padding="5,2" CornerRadius="8"
                                            Background="{DynamicResource WarningBrush}"
                                            Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="更新" FontSize="9" Foreground="#1E1E1E" FontWeight="SemiBold"/>
                                    </Border>
                                    <!-- 已安装标签 -->
                                    <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4"
                                            Background="{DynamicResource PrimaryLightBrush}"
                                            Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVis}}">
                                        <TextBlock Text="已安装" FontSize="10"
                                                   Foreground="{DynamicResource InfoBrush}"/>
                                    </Border>
                                    <!-- 未安装标签 -->
                                    <Border Margin="8,0,0,0" Padding="6,2" CornerRadius="4"
                                            Background="{DynamicResource BorderBrush}"
                                            Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVis}}">
                                        <TextBlock Text="未安装" FontSize="10"
                                                   Foreground="{DynamicResource TextTertiaryBrush}"/>
                                    </Border>
                                </StackPanel>

                                <!-- 分类 + 风险 -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="{Binding Category}" FontSize="11"
                                               Foreground="{DynamicResource InfoBrush}"
                                               Background="{DynamicResource PrimaryLightBrush}"
                                               Padding="6,2"/>
                                    <TextBlock FontSize="11" Margin="6,0,0,0" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextTertiaryBrush}">
                                        <Run Text="{Binding RiskLevel, Mode=OneWay, StringFormat='风险: {0}'}"/>
                                    </TextBlock>
                                </StackPanel>

                                <!-- 描述 -->
                                <TextBlock Grid.Row="2" Text="{Binding Description}" FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           TextWrapping="Wrap" TextTrimming="CharacterEllipsis"
                                           Margin="0,6,0,0"/>

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,0">
                                    <!-- 已安装：启动按钮 -->
                                    <Button Content="启动" Height="28" FontSize="12" Padding="12,0"
                                            Margin="0,0,6,0"
                                            Command="{Binding DataContext.LaunchToolCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Height" Value="28"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsInstalled}" Value="True"/>
                                                            <Condition Binding="{Binding LaunchPath}" Value=""/>
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </MultiDataTrigger>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- 未安装：安装按钮 -->
                                    <Button Content="安装" Height="28" FontSize="12"
                                            Padding="12,0" Margin="0,0,6,0"
                                            Command="{Binding DataContext.InstallToolCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Height" Value="28"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- 更新按钮 -->
                                    <Button Content="更新" Height="28" FontSize="12"
                                            Padding="12,0" Margin="0,0,6,0"
                                            Command="{Binding DataContext.UpgradeToolCommand,
                                                RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                                                <Setter Property="Height" Value="28"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding HasUpdate}" Value="False">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                    <!-- ⋯ 更多 按钮 -->
                                    <Button Content="⋯" Height="28" Width="36" FontSize="14"
                                            Padding="0" Margin="0,0,0,0"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Click="MoreButton_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
