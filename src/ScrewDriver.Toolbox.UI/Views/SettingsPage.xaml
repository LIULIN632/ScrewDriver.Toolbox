<Page x:Class="ScrewDriver.Toolbox.UI.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="设置">
    <Page.DataContext>
        <vm:SettingsViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            <TextBlock Text="设置" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,24"/>

            <!-- ========== 外观 ========== -->
            <TextBlock Text="外观" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <StackPanel>
                    <TextBlock Text="主题" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <Button Content="浅色" Width="100" Height="36" FontSize="13"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="LightTheme_Click"/>
                        <Button Content="深色" Width="100" Height="36" FontSize="13"
                                Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                Click="DarkTheme_Click"/>
                        <Button Content="跟随系统" Width="100" Height="36" FontSize="13"
                                Margin="8,0,0,0" Style="{StaticResource SecondaryButtonStyle}"
                                Click="SystemTheme_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ========== 通用 ========== -->
            <TextBlock Text="通用" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,24" Padding="20">
                <Grid Opacity="0.55">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="开机自启" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <Border Background="{DynamicResource WarningBrush}" CornerRadius="4"
                                    Padding="5,1" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="即将推出" FontSize="10" Foreground="#1E1E1E" FontWeight="SemiBold"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="系统启动时自动运行 ScrewDriver Toolbox"
                                   FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                    <CheckBox Grid.Column="1" IsChecked="False" IsEnabled="False"
                              Style="{StaticResource ToggleSwitchStyle}"
                              VerticalAlignment="Center" Opacity="0.4"/>
                </Grid>
            </Border>

            <!-- ========== 关于 ========== -->
            <TextBlock Text="关于" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,12"/>
            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,20" Padding="20">
                <StackPanel>
                    <TextBlock Text="ScrewDriver Toolbox" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                    <TextBlock Foreground="{DynamicResource TextSecondaryBrush}" FontSize="13">
                        <Run Text="版本 "/>
                        <Run Text="{Binding Version, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Runtime, Mode=OneWay}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,2,0,0"/>
                    <TextBlock Text="参考 DevToys + PowerToys + Windows 11 设计，打造 Windows 用户可信赖的系统工具箱"
                               FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}"
                               Margin="0,6,0,0" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,8,0,0" FontSize="13">
                        <Hyperlink NavigateUri="https://github.com" Click="GitHubLink_Click"
                                   Foreground="{DynamicResource PrimaryBrush}">
                            GitHub →
                        </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
