<Window x:Class="ScrewDriver.Toolbox.UI.Views.AddToolDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="添加工具" Height="260" Width="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="{DynamicResource BackgroundBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="工具名称:" FontSize="13" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <TextBox x:Name="NameBox" Grid.Row="1" FontSize="14" Height="32" Padding="8,4"
                 Margin="0,0,0,12"
                 Foreground="{DynamicResource TextPrimaryBrush}"
                 Background="{DynamicResource CardBackgroundBrush}"
                 CaretBrush="{DynamicResource PrimaryBrush}"
                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>

        <TextBlock Grid.Row="2" Text="分类:" FontSize="13" Margin="0,0,0,4"
                   Foreground="{DynamicResource TextPrimaryBrush}"/>
        <ComboBox x:Name="CategoryCombo" Grid.Row="3" IsEditable="True" FontSize="14"
                  Height="32" Padding="4,0" Margin="0,0,0,16"
                  Foreground="{DynamicResource TextPrimaryBrush}"
                  Background="{DynamicResource CardBackgroundBrush}"
                  BorderBrush="{DynamicResource BorderBrush}"
                  VerticalContentAlignment="Center"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="取消" Width="80" Height="32" FontSize="13"
                    Style="{StaticResource SecondaryButtonStyle}" Click="Cancel_Click"
                    Margin="0,0,10,0"/>
            <Button Content="确认添加" Width="96" Height="32" FontSize="13"
                    Style="{StaticResource PrimaryButtonStyle}" Click="Add_Click"/>
        </StackPanel>
    </Grid>
</Window>
