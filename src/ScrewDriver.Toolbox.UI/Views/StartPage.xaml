<Page x:Class="ScrewDriver.Toolbox.UI.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="启动页">
    <Page.DataContext>
        <vm:StartPageViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,36">
            <!-- 标题 -->
            <TextBlock Text="已安装工具" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- 全部工具 -->
            <TextBlock Text="全部工具" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <ItemsControl ItemsSource="{Binding FilteredTools}" HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ToolIconStyle}" Margin="4"
                                MouseLeftButtonDown="ToolIcon_Click"
                                ToolTipService.ShowDuration="5000">
                            <Border.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="200">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <Grid Width="96" Height="96"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Image Source="{Binding IconPath,
                                            Converter={StaticResource IconPathConverter}}"
                                           Width="48" Height="48"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="88"
                                               Margin="0,6,0,0"
                                               TextAlignment="Center"/>
                                </StackPanel>
                                <!-- 图钉按钮 -->
                                <Button Content="📌" Width="22" Height="22"
                                        FontSize="10" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        Cursor="Hand" Opacity="0.4"
                                        HorizontalAlignment="Right" VerticalAlignment="Top"
                                        Margin="0,2,2,0"
                                        Click="PinButton_Click"
                                        Tag="{Binding Name}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="BorderThickness" Value="0"/>
                                            <Setter Property="Opacity" Value="0.3"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空状态 -->
            <TextBlock Text="未找到工具，请前往工具仓库安装或拖入快捷方式"
                       FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,48,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredTools.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 底部状态栏 -->
            <Border Background="{DynamicResource NavBackgroundBrush}"
                    CornerRadius="8" Padding="12" Margin="0,32,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,24,0">
                        <Run Text="Windows: "/>
                        <Run Text="{Binding WindowsVersion, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,24,0">
                        <Run Text="{Binding IsAdmin, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                        <Run Text="设备: "/>
                        <Run Text="{Binding DeviceBrand, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
