<Page x:Class="ScrewDriver.Toolbox.UI.Views.StartPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:vm="clr-namespace:ScrewDriver.Toolbox.UI.ViewModels"
      Title="启动页">
    <Page.DataContext>
        <vm:StartPageViewModel/>
    </Page.DataContext>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,36">
            <!-- 标题 -->
            <TextBlock Text="已安装工具" FontSize="28" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,20"/>

            <!-- 全部工具 -->
            <TextBlock Text="全部工具" FontSize="14" FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,0,16"/>

            <ItemsControl ItemsSource="{Binding FilteredTools}" HorizontalAlignment="Left">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource ToolIconStyle}" Margin="4"
                                MouseLeftButtonDown="ToolIcon_Click"
                                ContextMenuOpening="ToolContextMenu_Opening">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="打开" Click="MenuOpen_Click"/>
                                    <MenuItem Header="打开文件位置" Click="MenuOpenLocation_Click"/>
                                    <Separator/>
                                    <MenuItem Header="从列表移除" Click="MenuRemove_Click"/>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <Border.ToolTip>
                                <ToolTip>
                                    <StackPanel MaxWidth="200">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </ToolTip>
                            </Border.ToolTip>
                            <Grid Width="96" Height="96"
                                  HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Grid Width="48" Height="48">
                                        <Image Source="{Binding LocalExePath,
                                                Converter={StaticResource ExeIconConverter}}"
                                               Width="48" Height="48"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        <TextBlock Text="📦" FontSize="28"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   IsHitTestVisible="False"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Name}" FontSize="12"
                                               Foreground="{DynamicResource TextPrimaryBrush}"
                                               HorizontalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxWidth="88"
                                               Margin="0,6,0,0"
                                               TextAlignment="Center"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- 空状态 -->
            <TextBlock Text="未找到工具，请前往工具仓库安装或拖入快捷方式"
                       FontSize="14" Foreground="{DynamicResource TextTertiaryBrush}"
                       HorizontalAlignment="Center" Margin="0,48,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FilteredTools.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 内置工具快捷栏 -->
            <Border Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    CornerRadius="12" Padding="16" Margin="0,24,0,16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Hosts 编辑 -->
                    <Button Style="{StaticResource NavItemHover}" Margin="0,0,8,0"
                            Click="BuiltInHosts_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📝" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="Hosts 编辑" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="编辑系统Hosts" FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- KMS 激活 -->
                    <Button Grid.Column="1" Style="{StaticResource NavItemHover}" Margin="4,0"
                            Click="BuiltInKms_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🔑" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="KMS 激活" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="查看激活状态" FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- WiFi 密码 -->
                    <Button Grid.Column="2" Style="{StaticResource NavItemHover}" Margin="4,0"
                            Click="BuiltInWifi_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="📶" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="WiFi 密码" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="查看WiFi密码" FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <!-- 证书拦截 -->
                    <Button Grid.Column="3" Style="{StaticResource NavItemHover}" Margin="8,0,0,0"
                            Click="BuiltInCert_Click">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="🛡️" FontSize="24" HorizontalAlignment="Center"/>
                            <TextBlock Text="证书拦截" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       HorizontalAlignment="Center" Margin="0,4,0,0"/>
                            <TextBlock Text="管理根证书" FontSize="10"
                                       Foreground="{DynamicResource TextTertiaryBrush}"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>
            <Border Background="{DynamicResource NavBackgroundBrush}"
                    CornerRadius="8" Padding="12" Margin="0,32,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,24,0">
                        <Run Text="Windows: "/>
                        <Run Text="{Binding WindowsVersion, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,24,0">
                        <Run Text="{Binding IsAdmin, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}">
                        <Run Text="设备: "/>
                        <Run Text="{Binding DeviceBrand, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
