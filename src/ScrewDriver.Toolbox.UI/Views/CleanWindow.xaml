<Window x:Class="ScrewDriver.Toolbox.UI.Views.CleanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="垃圾清理" Height="660" Width="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="垃圾清理" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="扫描并清理系统临时文件、C盘深度垃圾、浏览器缓存等"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 统计卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="总大小" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalSize" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="文件数" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalCount" FontSize="20" FontWeight="Bold"
                               Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="分类" FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtCategoryCount" FontSize="20" FontWeight="Bold"
                               Foreground="#8B5CF6" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,6">
            <Button x:Name="BtnScan" Content="扫描" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnScan_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnClean" Content="清理" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource DangerButtonStyle}"
                    IsEnabled="False" Click="BtnClean_Click" Margin="0,0,8,0"/>
            <Button Content="全选" Width="70" Height="32" FontSize="12"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnSelectAll_Click" Margin="0,0,8,0"/>
            <Button Content="取消全选" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnUnselectAll_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnCancel" Content="取消" Width="60" Height="32" FontSize="12"
                    Style="{StaticResource DangerButtonStyle}"
                    IsEnabled="False" Click="BtnCancel_Click" Margin="0,0,8,0"/>
            <Button Content="关闭休眠" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnDisableHibernate_Click" Margin="0,0,8,0"/>
            <CheckBox x:Name="ChkOldOnly" Content="7天前文件" FontSize="12"
                      Foreground="{DynamicResource TextSecondaryBrush}"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- 进度条 -->
        <StackPanel Grid.Row="3" x:Name="ProgressPanel" Visibility="Collapsed" Margin="0,0,0,6">
            <ProgressBar Height="4" IsIndeterminate="True"
                         Foreground="{DynamicResource PrimaryBrush}"
                         Background="{DynamicResource BorderBrush}"/>
            <TextBlock x:Name="TxtProgress" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 清理项列表 -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsClean">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,6" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 图标 -->
                                <Border Width="36" Height="36" CornerRadius="8"
                                        Background="{DynamicResource PrimaryLightBrush}"
                                        Margin="0,0,12,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Icon}" FontSize="18"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <!-- 信息 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <!-- 高风险标签 -->
                                        <Border Padding="5,1" CornerRadius="4" Margin="8,0,0,0"
                                                Background="#FEE2E2" VerticalAlignment="Center"
                                                Visibility="{Binding IsRisk, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="高风险" FontSize="10" Foreground="#991B1B"/>
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SizeText}" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- 勾选 -->
                                <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 结果提示 -->
        <TextBlock Grid.Row="5" x:Name="TxtResult" FontSize="13" FontWeight="SemiBold"
                   Foreground="#10B981" Margin="0,10,0,0" Visibility="Collapsed"/>

        <!-- 关闭 -->
        <Button Grid.Row="6" Content="关闭" Height="36" FontSize="13"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="BtnClose_Click" Margin="0,10,0,0"/>
    </Grid>
</Window>
