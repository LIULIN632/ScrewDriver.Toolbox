<Window x:Class="ScrewDriver.Toolbox.UI.Views.CleanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="垃圾清理" Height="620" Width="540"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BackgroundBrush}"
        Foreground="{DynamicResource TextPrimaryBrush}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="垃圾清理" FontSize="24" FontWeight="Bold"
                       Foreground="{DynamicResource TextPrimaryBrush}"/>
            <TextBlock Text="扫描并清理系统临时文件、浏览器缓存、回收站等垃圾文件，释放磁盘空间"
                       FontSize="13" Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- 统计卡片 -->
        <Grid Grid.Row="1" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,6,0">
                <StackPanel>
                    <TextBlock Text="总大小" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalSize" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryBrush}" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="6,0">
                <StackPanel>
                    <TextBlock Text="文件数" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtTotalCount" FontSize="20" FontWeight="Bold"
                               Foreground="#10B981" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Style="{StaticResource CardStyle}" Margin="6,0,0,0">
                <StackPanel>
                    <TextBlock Text="分类" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"/>
                    <TextBlock x:Name="TxtCategoryCount" FontSize="20" FontWeight="Bold"
                               Foreground="#8B5CF6" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 操作按钮 -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,12">
            <Button x:Name="BtnScan" Content="扫描" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="BtnScan_Click" Margin="0,0,8,0"/>
            <Button x:Name="BtnClean" Content="清理" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource DangerButtonStyle}"
                    IsEnabled="False" Click="BtnClean_Click" Margin="0,0,8,0"/>
            <Button Content="全选" Width="70" Height="32" FontSize="12"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnSelectAll_Click" Margin="0,0,8,0"/>
            <Button Content="取消全选" Width="80" Height="32" FontSize="12"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="BtnUnselectAll_Click"/>
        </StackPanel>

        <!-- 清理项列表 -->
        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ItemsClean">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,8" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- 图标 -->
                                <TextBlock Grid.Column="0" Text="{Binding Icon}" FontSize="24"
                                           Margin="0,0,12,0" VerticalAlignment="Center"/>
                                <!-- 信息 -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="12"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                        <TextBlock Text="{Binding SizeText}" FontSize="12"
                                                   Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding CountText}" FontSize="12"
                                                   Foreground="{DynamicResource TextTertiaryBrush}" Margin="8,0,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                                <!-- 勾选 -->
                                <CheckBox Grid.Column="2" IsChecked="{Binding IsSelected}"
                                          VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 结果提示 -->
        <TextBlock Grid.Row="4" x:Name="TxtResult" FontSize="13" FontWeight="SemiBold"
                   Foreground="#10B981" Margin="0,12,0,0" Visibility="Collapsed"/>

        <!-- 关闭 -->
        <Button Grid.Row="5" Content="关闭" Height="36" FontSize="13"
                Style="{StaticResource SecondaryButtonStyle}"
                Click="BtnClose_Click" Margin="0,12,0,0"/>
    </Grid>
</Window>
