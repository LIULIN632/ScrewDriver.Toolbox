<!-- ToolCard.xaml - 工具展示卡片 -->
<UserControl
    x:Class="ScrewDriver.Toolbox.Controls.ToolCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border
        Background="{ThemeResource CardBackground}"
        CornerRadius="12"
        Padding="16"
        Width="280"
        Height="160">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 名称 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{x:Bind ToolName, Mode=OneWay}"
                           Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Border CornerRadius="4" Padding="4,2" Background="{ThemeResource SystemAccentColor}">
                    <TextBlock Text="{x:Bind Version, Mode=OneWay}"
                               FontSize="10"
                               Foreground="White"/>
                </Border>
            </StackPanel>

            <!-- 来源 -->
            <TextBlock Grid.Row="1"
                       Text="{x:Bind Source, Mode=OneWay}"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorTertiary}"/>

            <!-- 描述 -->
            <TextBlock Grid.Row="2"
                       Text="{x:Bind Description, Mode=OneWay}"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       TextTrimming="WordEllipsis"
                       TextWrapping="Wrap"
                       Margin="0,4"
                       VerticalAlignment="Center"/>

            <!-- 安装按钮 -->
            <Button Grid.Row="3"
                    Content="{x:Bind ButtonText, Mode=OneWay}"
                    HorizontalAlignment="Right"
                    Click="OnInstallClick"
                    Style="{StaticResource AccentButtonStyle}"/>
        </Grid>
    </Border>
</UserControl>
