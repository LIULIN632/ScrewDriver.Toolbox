<!-- ToolRepositoryPage.xaml - 工具仓库 -->
<Page
    x:Class="ScrewDriver.Toolbox.Views.ToolRepositoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ScrewDriver.Toolbox.Controls"
    xmlns:vm="using:ScrewDriver.Toolbox.ViewModels"
    xmlns:models="using:ScrewDriver.Toolbox.Models"
    x:DefaultBindMode="OneWay">

    <Grid Padding="24,24,40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="{x:Bind ViewModel.PageTitle}" Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.PageDescription}" Style="{StaticResource PageSubHeaderStyle}"/>
        </StackPanel>

        <!-- 搜索框 -->
        <TextBox Grid.Row="1"
                 Style="{StaticResource SearchBoxStyle}"
                 Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="搜索工具名称或描述..."
                 Width="500"
                 HorizontalAlignment="Left"
                 Margin="0,0,0,16"/>

        <!-- 分类标签 -->
        <ScrollViewer Grid.Row="2" HorizontalScrollMode="Auto" VerticalScrollMode="Disabled" Margin="0,0,0,16">
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Categories}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <Button Content="{x:Bind}" Margin="0,0,8,0" MinWidth="80" Height="32"
                                CornerRadius="16" FontSize="13"/>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
                <ItemsRepeater.Layout>
                    <StackLayout Orientation="Horizontal"/>
                </ItemsRepeater.Layout>
            </ItemsRepeater>
        </ScrollViewer>

        <!-- 工具列表 -->
        <GridView Grid.Row="3" SelectionMode="None" IsItemClickEnabled="True"
                  ItemsSource="{x:Bind ViewModel.Tools}"
                  Margin="0,8,0,0">
            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" ItemWidth="280" ItemHeight="160"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:ToolModel">
                    <controls:ToolCard ToolName="{x:Bind Name}"
                                       Description="{x:Bind Description}"
                                       Version="{x:Bind Version}"
                                       Source="{x:Bind Category}"/>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>
