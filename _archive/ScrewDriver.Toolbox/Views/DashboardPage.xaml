<!-- DashboardPage.xaml - 首页 -->
<Page
    x:Class="ScrewDriver.Toolbox.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ScrewDriver.Toolbox.Controls"
    xmlns:vm="using:ScrewDriver.Toolbox.ViewModels"
    x:DefaultBindMode="OneWay">

    <ScrollViewer>
        <StackPanel Padding="24,24,40,24" Spacing="16">

            <!-- 欢迎语 -->
            <TextBlock Text="{x:Bind ViewModel.WelcomeText}"
                       Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Style="{StaticResource PageSubHeaderStyle}"
                       Visibility="{x:Bind ViewModel.DeviceInfo.WindowsVersion, Converter={StaticResource StringToVisibilityConverter}, FallbackValue=Collapsed}">
                <Run Text="{x:Bind ViewModel.DeviceInfo.Manufacturer}"/>
                <Run Text="{x:Bind ViewModel.DeviceInfo.Model}"/>
                <Run Text="·"/>
                <Run Text="{x:Bind ViewModel.DeviceInfo.WindowsVersion}"/>
            </TextBlock>

            <!-- 搜索框 -->
            <TextBox Style="{StaticResource SearchBoxStyle}"
                     PlaceholderText="搜索工具、设置、场景..."
                     Width="400"
                     HorizontalAlignment="Left"/>

            <!-- 系统概览 2×2 -->
            <TextBlock Text="系统概览" Style="{StaticResource SectionHeaderStyle}"/>
            <GridView SelectionMode="None" IsItemClickEnabled="False">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="180" ItemHeight="120"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <controls:StatusCard ComponentName="CPU" Value="{x:Bind ViewModel.CpuStatus.Value}" Unit="{x:Bind ViewModel.CpuStatus.Unit}" StatusDescription="{x:Bind ViewModel.CpuStatus.StatusColor}"/>
                <controls:StatusCard ComponentName="内存" Value="{x:Bind ViewModel.MemoryStatus.Value}" Unit="{x:Bind ViewModel.MemoryStatus.Unit}" StatusDescription="{x:Bind ViewModel.MemoryStatus.StatusColor}"/>
                <controls:StatusCard ComponentName="磁盘" Value="{x:Bind ViewModel.DiskStatus.Value}" Unit="{x:Bind ViewModel.DiskStatus.Unit}" StatusDescription="{x:Bind ViewModel.DiskStatus.StatusColor}"/>
                <controls:StatusCard ComponentName="系统" Value="{x:Bind ViewModel.SystemStatus.Value}" Unit="{x:Bind ViewModel.SystemStatus.Unit}" StatusDescription="运行中"/>
            </GridView>

            <!-- 快捷操作 -->
            <TextBlock Text="快捷操作" Style="{StaticResource SectionHeaderStyle}"/>
            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button Content="🚀 一键优化" Command="{x:Bind ViewModel.QuickOptimizeCommand}" Style="{StaticResource AccentButtonStyle}" Width="140" Height="48" CornerRadius="8"/>
                <Button Content="🛠 一键修复" Command="{x:Bind ViewModel.QuickRepairCommand}" Width="140" Height="48" CornerRadius="8"/>
                <Button Content="📦 一键装机" Command="{x:Bind ViewModel.QuickSetupCommand}" Width="140" Height="48" CornerRadius="8"/>
                <Button Content="📊 生成报告" Command="{x:Bind ViewModel.GenerateReportCommand}" Width="140" Height="48" CornerRadius="8"/>
            </StackPanel>

            <!-- 最近使用 -->
            <TextBlock Text="最近使用" Style="{StaticResource SectionHeaderStyle}"/>
            <GridView SelectionMode="None">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
            </GridView>
        </StackPanel>
    </ScrollViewer>
</Page>
