<!-- ScenarioPage.xaml - 场景方案 -->
<Page
    x:Class="ScrewDriver.Toolbox.Views.ScenarioPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:ScrewDriver.Toolbox.Controls"
    xmlns:models="using:ScrewDriver.Toolbox.Models"
    x:DefaultBindMode="OneWay">

    <Grid Padding="24,24,40,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 头部 -->
        <StackPanel Grid.Row="0" Spacing="4">
            <TextBlock Text="{x:Bind ViewModel.PageTitle}" Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.PageDescription}" Style="{StaticResource PageSubHeaderStyle}"/>
        </StackPanel>

        <!-- 场景方案卡片 -->
        <ScrollViewer Grid.Row="2" Margin="0,8,0,0">
            <GridView SelectionMode="None" IsItemClickEnabled="True"
                      ItemsSource="{x:Bind ViewModel.Scenarios}">
                <GridView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsWrapGrid Orientation="Horizontal" ItemWidth="320" ItemHeight="200"/>
                    </ItemsPanelTemplate>
                </GridView.ItemsPanel>
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:ScenarioModel">
                        <controls:ScenarioCard ScenarioName="{x:Bind Name}"
                                                ScenarioDescription="{x:Bind Description}"
                                                ScenarioIcon="{x:Bind Icon}"/>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>
