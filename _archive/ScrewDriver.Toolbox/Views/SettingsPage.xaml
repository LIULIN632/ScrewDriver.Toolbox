<!-- SettingsPage.xaml - 设置页面 -->
<Page
    x:Class="ScrewDriver.Toolbox.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:DefaultBindMode="OneWay">

    <ScrollViewer>
        <StackPanel Padding="24,24,40,24" Spacing="16">
            <TextBlock Text="{x:Bind ViewModel.PageTitle}" Style="{StaticResource PageHeaderStyle}"/>
            <TextBlock Text="{x:Bind ViewModel.PageDescription}" Style="{StaticResource PageSubHeaderStyle}"/>

            <!-- 外观 -->
            <Border Background="{ThemeResource CardBackground}" CornerRadius="12" Padding="20">
                <StackPanel Spacing="12">
                    <TextBlock Text="外观" Style="{StaticResource SectionHeaderStyle}"/>
                    <ToggleSwitch Header="深色模式" IsOn="{x:Bind ViewModel.IsDarkMode, Mode=TwoWay}"/>
                    <ToggleSwitch Header="跟随系统主题" IsOn="{x:Bind ViewModel.FollowSystemTheme, Mode=TwoWay}"/>
                </StackPanel>
            </Border>

            <!-- 关于 -->
            <Border Background="{ThemeResource CardBackground}" CornerRadius="12" Padding="20">
                <StackPanel Spacing="8">
                    <TextBlock Text="关于" Style="{StaticResource SectionHeaderStyle}"/>
                    <TextBlock>版本: <Run Text="{x:Bind ViewModel.CurrentVersion}"/></TextBlock>
                    <TextBlock Text="ScrewDriver Toolbox - 螺丝刀工具箱" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    <TextBlock Text="面向 Windows 用户的可信工具箱" Foreground="{ThemeResource TextFillColorTertiary}"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
