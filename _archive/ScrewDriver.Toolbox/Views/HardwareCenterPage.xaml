<!-- HardwareCenterPage.xaml - 硬件检测（占位） -->
<Page
    x:Class="ScrewDriver.Toolbox.Views.HardwareCenterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:DefaultBindMode="OneWay">

    <StackPanel Padding="24,24,40,24" Spacing="16">
        <TextBlock Text="{x:Bind ViewModel.PageTitle}" Style="{StaticResource PageHeaderStyle}"/>
        <TextBlock Text="{x:Bind ViewModel.PageDescription}" Style="{StaticResource PageSubHeaderStyle}"/>

        <Border Background="{ThemeResource CardBackground}" CornerRadius="12" Padding="32">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                <TextBlock Text="🖥️" FontSize="64" HorizontalAlignment="Center"/>
                <TextBlock Text="硬件检测模块开发中"
                           Style="{StaticResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="预计下一版本上线"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>
