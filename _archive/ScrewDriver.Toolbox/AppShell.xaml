<!-- AppShell.xaml - 主导航框架 (NavigationView) -->
<NavigationView
    x:Class="ScrewDriver.Toolbox.AppShell"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="using:ScrewDriver.Toolbox.Views"
    IsBackButtonVisible="Collapsed"
    IsSettingsVisible="False"
    OpenPaneLength="240"
    CompactPaneLength="64"
    PaneDisplayMode="LeftCompact"
    AlwaysShowHeader="False"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <!-- 一级导航 -->
    <NavigationView.MenuItems>
        <NavigationViewItem Tag="dashboard" Icon="Home" Content="首页" />
        <NavigationViewItem Tag="tools" Icon="AllApps" Content="工具仓库" />
        <NavigationViewItem Tag="optimize" Icon="Setting" Content="系统优化" />
        <NavigationViewItem Tag="repair" Icon="Repair" Content="系统修复" />
        <NavigationViewItem Tag="hardware" Icon="SolidStar" Content="硬件检测" />
        <NavigationViewItem Tag="brand" Icon="Shop" Content="品牌工具" />
        <NavigationViewItem Tag="scenario" Icon="Play" Content="场景方案" />
        <NavigationViewItem Tag="data" Icon="ReportDocument" Content="数据中心" />
    </NavigationView.MenuItems>

    <!-- 底部导航 -->
    <NavigationView.PaneFooter>
        <StackPanel>
            <NavigationViewItem Tag="update" Icon="Refresh" Content="更新中心" />
            <NavigationViewItem Tag="settings" Icon="Setting" Content="设置" />
            <NavigationViewItem Tag="about" Icon="Help" Content="关于" />
        </StackPanel>
    </NavigationView.PaneFooter>

    <Frame x:Name="ContentFrame" />
</NavigationView>
