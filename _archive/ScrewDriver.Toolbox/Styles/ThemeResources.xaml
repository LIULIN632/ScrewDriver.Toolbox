<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:helpers="using:ScrewDriver.Toolbox.Helpers">

    <helpers:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>

    <ResourceDictionary.ThemeDictionaries>
        <!-- 浅色主题 -->
        <ResourceDictionary x:Key="Light">
            <Color x:Key="CardBackgroundColor">#FFFFFF</Color>
            <Color x:Key="PageHeaderBackgroundColor">#F5F7FA</Color>
        </ResourceDictionary>

        <!-- 深色主题 -->
        <ResourceDictionary x:Key="Dark">
            <Color x:Key="CardBackgroundColor">#2A2A2A</Color>
            <Color x:Key="PageHeaderBackgroundColor">#1E1E1E</Color>
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>
